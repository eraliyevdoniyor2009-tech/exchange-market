# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  Copy to .env.local for development, set in Railway for prod
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL: paste the "DATABASE_URL" from your Railway service
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://postgres:password@localhost:5432/marketplace_db"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-32-random-chars"
# Production: set to your Railway domain, e.g. https://marketplace.up.railway.app
AUTH_URL="http://localhost:3000"

# ── Cloudinary ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
# Create an "Unsigned" upload preset in your Cloudinary dashboard
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="marketplace_unsigned"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Marketplace"

# ── Rate limiting (optional – set on Railway) ─────────────────────────────────
# Used by the API rate limiter middleware
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW_MS="60000"

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV="development"
